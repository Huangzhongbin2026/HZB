APP_NAME=Private Knowledge Cloud API
API_V1_PREFIX=/api/v1
DATABASE_URL=sqlite:///./knowledge_cloud.db
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-bytes
JWT_ALGORITHM=HS256
JWT_EXP_MINUTES=10080
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password
CLIP_TIMEOUT_SECONDS=12
RAG_CHUNK_SIZE=700
RAG_OVERLAP=120
# 可选：作为 UI 未配置模型时的默认回退配置
AI_PROVIDER_LABEL=环境变量默认配置
AI_API_BASE=
AI_API_KEY=
AI_MODEL=gpt-4.1-mini
